# Postgres
POSTGRES_USER=photoprism
POSTGRES_PASSWORD=changeme

# Grafana
GRAFANA_PASSWORD=admin

# RabbitMQ (optional override)
# RABBITMQ_USER=guest
# RABBITMQ_PASSWORD=guest

# S3 / Chameleon CHI@TACC
S3_ENDPOINT_URL=https://chi.tacc.chameleoncloud.org:7480
S3_BUCKET=training-module-proj03
S3_PREFIX=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Data generator (Photoprism traffic simulator)
PHOTOPRISM_URL=http://photoprism:2342
PHOTOPRISM_USERNAME=admin
PHOTOPRISM_PASSWORD=
MEAN_THINK_SECONDS=2.0

# Qdrant (optional overrides)
# QDRANT_HOST=qdrant
# QDRANT_PORT=6333
# QDRANT_COLLECTION=photoprism_images

# Serving model
MODEL_NAME=clip-ViT-B-32
MODEL_VERSION=clip-ViT-B-32-v1
DEVICE=auto
AESTHETIC_MODEL_TYPE=mobilenet_v3_large_fusion
# Uncomment when training provides checkpoint:
# AESTHETIC_CHECKPOINT_PATH=/checkpoints/aesthetic/best.pt
# CHECKPOINT_PATH=/checkpoints/semantic/best.pt
