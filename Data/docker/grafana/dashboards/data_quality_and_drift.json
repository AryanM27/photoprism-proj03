{
  "__inputs": [],
  "__requires": [],
  "annotations": {"list": []},
  "description": "Data quality and drift monitoring across ingestion, manifest compilation, and live inference.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "title": "Ingestion Quality",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "short"},
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 1},
      "id": 1,
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "sum by (status) (pg_image_status_total{job=\"postgres\"})", "legendFormat": "{{status}}"}],
      "title": "Images by Status",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 6, "w": 9, "x": 6, "y": 1},
      "id": 2,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [{"expr": "rate(validation_check_total{result=\"fail\"}[5m])", "legendFormat": "{{reason}}"}],
      "title": "Validation Failures by Reason (rate/5m)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "gridPos": {"h": 6, "w": 9, "x": 15, "y": 1},
      "id": 3,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [{"expr": "histogram_quantile(0.95, rate(celery_task_duration_seconds_bucket[5m]))", "legendFormat": "p95 {{worker}}"}],
      "title": "Celery Task Duration p95 by Worker",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "short", "min": 0, "max": 1}, "overrides": []},
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 7},
      "id": 4,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "horizontal"},
      "targets": [{"expr": "pg_image_aesthetic_score_avg_avg_aesthetic_score{job=\"postgres\"}", "legendFormat": "{{source_dataset}}"}],
      "title": "Avg Aesthetic Score by Dataset",
      "type": "bargauge"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 14},
      "id": 101,
      "title": "Training Set Drift",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 15},
      "id": 5,
      "options": {"showHeader": true},
      "targets": [{"expr": "pg_manifest_drift_score_drift_score{job=\"postgres\"}", "legendFormat": "{{version_tag}} / {{manifest_kind}} / {{column_name}}", "instant": true}],
      "title": "Latest Drift Scores (all columns)",
      "transformations": [{"id": "labelsToFields", "options": {}}],
      "type": "table"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "short", "min": 0, "max": 1}, "overrides": []},
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 15},
      "id": 6,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [{"expr": "pg_manifest_drift_score_drift_score{job=\"postgres\",column_name=\"aesthetic_score\"}", "legendFormat": "{{manifest_kind}} {{version_tag}}"}],
      "title": "Drift Score: aesthetic_score over Versions",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "short", "noValue": "0"}, "overrides": []},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 22},
      "id": 7,
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "count(pg_manifest_drift_score_drift_detected{job=\"postgres\"} == 1) or vector(0)", "legendFormat": "Drifted columns"}],
      "title": "Columns with Drift Detected",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 4, "w": 18, "x": 6, "y": 22},
      "id": 8,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [{"expr": "pg_manifest_row_count_row_count{job=\"postgres\"}", "legendFormat": "{{version_tag}} {{manifest_kind}}", "instant": true}],
      "title": "Manifest Row Counts by Version",
      "type": "barchart"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 27},
      "id": 102,
      "title": "Live Inference",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 28},
      "id": 9,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [{"expr": "rate(inference_search_total[5m])", "legendFormat": "{{result}}"}],
      "title": "Search Results Rate by Outcome",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 28},
      "id": 10,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [{"expr": "rate(inference_empty_results_total[5m])", "legendFormat": "empty results/s"}],
      "title": "Empty Results Rate",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 35},
      "id": 11,
      "options": {"calculate": false, "color": {"mode": "scheme", "scheme": "Spectral"}, "yAxis": {"unit": "short"}},
      "targets": [{"expr": "rate(inference_query_length_chars_bucket[5m])", "legendFormat": "{{le}}"}],
      "title": "Query Length Distribution",
      "type": "heatmap"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "short", "min": 0, "max": 1}, "overrides": []},
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 35},
      "id": 12,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [
        {"expr": "histogram_quantile(0.95, rate(inference_top_k_score_bucket{stage=\"rerank\"}[5m]))", "legendFormat": "p95 rerank"},
        {"expr": "histogram_quantile(0.50, rate(inference_top_k_score_bucket{stage=\"rerank\"}[5m]))", "legendFormat": "p50 rerank"}
      ],
      "title": "Top-K Rerank Score p50/p95",
      "type": "timeseries"
    }
  ],
  "refresh": "1m",
  "schemaVersion": 38,
  "tags": ["mlops", "drift", "data-quality"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 2,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": {"from": "now-24h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Data Quality & Drift",
  "uid": "data-quality-drift",
  "version": 1
}
