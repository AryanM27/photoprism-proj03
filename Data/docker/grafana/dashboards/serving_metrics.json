{
  "title": "Serving API Metrics",
  "uid": "serving-api-metrics",
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "id": 1,
      "title": "Search Request Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(inference_search_total[1m])",
          "legendFormat": "{{ result }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 2,
      "title": "P95 Search Latency",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{handler='/search'}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{handler='/search'}[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 3,
      "title": "Total Searches",
      "type": "stat",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(inference_search_total)",
          "legendFormat": "Total",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Empty Results",
      "type": "stat",
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(inference_empty_results_total)",
          "legendFormat": "Empty",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 10 }] } }
      }
    },
    {
      "id": 5,
      "title": "Error Rate",
      "type": "stat",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(rate(inference_search_total{result='error'}[5m])) / sum(rate(inference_search_total[5m])) * 100",
          "legendFormat": "Error %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 5 }] } }
      }
    },
    {
      "id": 6,
      "title": "Active Replicas",
      "type": "stat",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "count(up{job='serving-api'})",
          "legendFormat": "Replicas",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "red", "value": 0 }, { "color": "yellow", "value": 1 }, { "color": "green", "value": 3 }] } }
      }
    },
    {
      "id": 7,
      "title": "Top-K Similarity Scores",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(inference_top_k_score_bucket{stage='vector'}[5m])) by (le))",
          "legendFormat": "vector p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(inference_top_k_score_bucket{stage='rerank'}[5m])) by (le))",
          "legendFormat": "rerank p50",
          "refId": "B"
        }
      ]
    },
    {
      "id": 8,
      "title": "Query Embedding Norm",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(inference_query_embedding_norm_bucket[5m])) by (le))",
          "legendFormat": "norm p50 (should be ~1.0)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Score Spread (Retrieval Quality)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(inference_score_spread_bucket[5m])) by (le))",
          "legendFormat": "spread p50",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "Query Length Distribution",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(inference_query_length_chars_bucket[5m])) by (le))",
          "legendFormat": "length p50 (chars)",
          "refId": "A"
        }
      ]
    }
  ],
  "time": { "from": "now-1h", "to": "now" }
}
