# Copy to .env and fill in values — never commit .env
POSTGRES_USER=photoprism
POSTGRES_PASSWORD=changeme

# Chameleon S3 credentials — generate once per user via provision_storage.ipynb
# Replaced by Chameleon native S3 (CHI@TACC)
AWS_ACCESS_KEY_ID=<fill-in-your-EC2-access-key>
AWS_SECRET_ACCESS_KEY=<fill-in-your-EC2-secret-key>
S3_ENDPOINT_URL=https://chi.tacc.chameleoncloud.org:7480
S3_BUCKET=training-module-proj03
S3_PREFIX=data_arm9337

GRAFANA_PASSWORD=changeme

# NOTE: Use service name "qdrant" inside Docker Compose; use "localhost" for local dev outside containers
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=photoprism_images
EMBEDDING_MODEL=clip-ViT-B-32

# Service URLs (override with VM IP for remote access)
ADMINER_URL=http://localhost:8080
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_MANAGEMENT_URL=http://localhost:15672
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3000
FEATURES_API_URL=http://localhost:8000
QDRANT_URL=http://localhost:6333
