FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    libjpeg-dev libpng-dev \
    && rm -rf /var/lib/apt/lists/*

COPY docker/requirements.data-generator.txt .
RUN pip install --no-cache-dir -r requirements.data-generator.txt

COPY src/ ./src/

RUN useradd -m -u 1000 worker && chown -R worker:worker /app
USER worker

ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1

CMD ["python", "-m", "src.data_generator.photoprism.loop"]
