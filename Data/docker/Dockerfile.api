FROM python:3.11-slim
WORKDIR /app
RUN pip install --no-cache-dir \
    fastapi \
    uvicorn[standard] \
    Pillow \
    requests \
    sentence-transformers==3.0.1 \
    qdrant-client==1.9.1
RUN useradd -m -u 1000 apiuser
COPY src/ ./src/
USER apiuser
CMD ["uvicorn", "src.data_pipeline.features.online:app", "--host", "0.0.0.0", "--port", "8000"]
