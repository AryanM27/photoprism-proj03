{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["image_id"],
  "properties": {
    "image_id":       {"type": "string"},
    "text":           {"type": "string", "description": "Caption or description used for semantic search"},
    "source_dataset": {"type": "string", "enum": ["yfcc", "ava_subset"]},
    "width":          {"type": "integer"},
    "height":         {"type": "integer"},
    "format":         {"type": "string"},
    "exif_json":      {"type": "string"},
    "tags":           {"type": "string"},
    "captured_at":    {"type": "string", "format": "date-time"},
    "normalized_at":  {"type": "string", "format": "date-time"}
  }
}
