{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "One entry per line in semantic_<split>_<version>.jsonl — consumed by training pipeline",
  "type": "object",
  "required": ["image_id", "image_uri", "text", "split", "source_dataset"],
  "properties": {
    "image_id":       {"type": "string"},
    "image_uri":      {"type": "string", "description": "S3-compatible URI e.g. s3://photoprism-proj03/images/img.jpg"},
    "text":           {"type": "string", "description": "Caption or description for contrastive learning"},
    "split":          {"type": "string", "enum": ["train", "val"]},
    "source_dataset": {"type": "string", "enum": ["yfcc", "ava_subset"]}
  }
}
